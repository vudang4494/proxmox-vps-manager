# ===== Proxmox connection =====
# Host/IP của Proxmox (không kèm https:// và không kèm :8006).
# Service deploy NGAY TRÊN host Proxmox → mặc định 127.0.0.1; chỉ đổi sang IP Proxmox nếu chạy từ máy khác qua mạng.
PROXMOX_HOST=127.0.0.1
PROXMOX_PORT=8006

# API Token: tạo trong Datacenter > Permissions > API Tokens
# user dạng: root@pam  hoặc  apiuser@pve
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=automation
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# verify TLS cert của Proxmox. Đặt false nếu dùng self-signed cert.
PROXMOX_VERIFY_SSL=false

# ===== Mặc định khi tạo VPS =====
# Node Proxmox sẽ tạo VM (tên node, vd: pve, pve)
DEFAULT_NODE=pve
# VMID của template dùng để clone
DEFAULT_TEMPLATE_ID=9000
# Storage chứa disk của VM mới (vd: local-lvm, local-zfs, ceph...)
DEFAULT_STORAGE=local-lvm
# Network bridge (vd: vmbr0)
DEFAULT_BRIDGE=vmbr0

# ===== Bảo mật API của chính service này =====
# Client phải gửi header: X-API-Key: <giá trị này>. Để trống = tắt auth.
API_KEY=change-me-please
