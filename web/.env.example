# Cổng web panel
PORT=9999

# URL tới FastAPI Proxmox API.
# - Chạy trên Mac qua SSH tunnel: http://127.0.0.1:8000
#   (mở tunnel: ssh -p 22 -L 8000:127.0.0.1:8000 -L 8006:127.0.0.1:8006 root@YOUR_PROXMOX_HOST)
# - Nếu deploy chung host Proxmox: http://127.0.0.1:8000
PROXMOX_API_URL=http://127.0.0.1:8000

# API key của FastAPI service (lấy ở file ../Key, dòng API_KEY=...)
API_KEY=change-me

# ── Đăng nhập web panel (BẮT BUỘC — thiếu PANEL_PASS_HASH thì không đăng nhập được) ──
PANEL_USER=admin
# Mật khẩu lưu dạng hash scrypt "salt:hex" (KHÔNG để plaintext). Sinh hash:
#   node -e 'const c=require("crypto");const s=c.randomBytes(16).toString("hex");const h=c.scryptSync(process.argv[1],s,64).toString("hex");console.log(s+":"+h)' "MatKhauCuaBan"
PANEL_PASS_HASH=
# Khoá ký session — nên đặt để phiên sống qua restart (bỏ trống = random mỗi lần khởi động):
#   openssl rand -hex 32
SESSION_SECRET=

# ── Shell Console (xterm.js) ──
# WebSocket tới Proxmox. Mặc định 127.0.0.1:8006 — cần SSH tunnel forward THÊM cổng 8006.
PROXMOX_WS_URL=https://127.0.0.1:8006
